# ============================================================
# Frontend — variables d'environnement
# Copier ce fichier en frontend/.env.local et remplir les valeurs
# NE JAMAIS committer frontend/.env.local (déjà dans .gitignore)
# ============================================================

# Clé API interne (doit correspondre à AGENTS_API_KEY dans le .env backend)
# Laisser vide si AGENTS_API_KEY n'est pas configuré (dev local sans auth)
VITE_API_KEY=your-agents-api-key-here

# URL de base de l'API (optionnel)
# Laisser vide quand le frontend est servi par FastAPI sur le même hôte (/app)
# Définir si le frontend est déployé sur un hôte différent de l'API
# Exemple : VITE_API_URL=https://api.mondomaine.com
VITE_API_URL=
