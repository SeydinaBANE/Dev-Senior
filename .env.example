# ============================================================
# CONFIGURATION — copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env (il est dans .gitignore)
# ============================================================

# === LLMs Cloud ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here          # optionnel

# === Ollama (Docker) ===
OLLAMA_BASE_URL=http://localhost:11434
USE_CLOUD=false                               # true = utiliser Claude API au lieu d'Ollama

# === Modèles ===
DEV_SENIOR_MODEL=qwen2.5-coder:7b            # modèle local Dev Senior
DEV_SENIOR_MODEL_CLOUD=claude-sonnet-4-6     # fallback cloud
BIZ_MANAGER_MODEL=llama3.1:8b               # modèle local Biz Manager
BIZ_MANAGER_MODEL_CLOUD=claude-sonnet-4-6

# === Mémoire vectorielle (ChromaDB) ===
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TOKEN=change-this-token               # ⚠ changer en prod
EMBED_MODEL=nomic-embed-text                 # modèle Ollama pour les embeddings

# === API agents ===
# ⚠ OBLIGATOIRE en prod — laisser vide seulement en dev local
AGENTS_API_KEY=generate-a-strong-random-key-here
DOCS_ENABLED=true                            # false en prod (désactive Swagger)
CORS_ORIGINS=http://localhost:5678,http://localhost:3000

# === Observabilité ===
LOGFIRE_TOKEN=your_logfire_token_here        # laisser vide → logs console uniquement
APP_VERSION=0.1.0

# === MCP — GitHub ===
GITHUB_TOKEN=your_github_token_here          # scopes requis : repo

# === MCP — Google Workspace ===
GOOGLE_CREDENTIALS_FILE=credentials.json     # télécharger depuis Google Cloud Console
GOOGLE_TOKEN_FILE=token.json                 # généré automatiquement au 1er lancement

# === MCP — CRM (HubSpot par défaut) ===
CRM_TYPE=hubspot
CRM_API_KEY=your_hubspot_private_app_token
CRM_BASE_URL=                                # laisser vide pour HubSpot

# === MCP — SEO ===
SEARCH_CONSOLE_SITE_URL=https://tonsite.com/
DATAFORSEO_LOGIN=your_dataforseo_login       # optionnel
DATAFORSEO_PASSWORD=your_dataforseo_password # optionnel

# === n8n ===
N8N_USER=admin
N8N_PASSWORD=change-this-strong-password     # ⚠ changer impérativement
AGENTS_API_URL=http://host.docker.internal:8080

# === Emails (pour les workflows n8n) ===
SENDER_EMAIL=ton@email.com
REPORT_RECIPIENTS=equipe@email.com
CONTENT_TEAM_EMAIL=content@email.com
SLACK_ALERT_CHANNEL=#alertes
