# === LLMs Cloud ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# === Ollama (Docker) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Modèles par défaut ===
DEV_SENIOR_MODEL=qwen2.5-coder:7b       # local via Ollama
DEV_SENIOR_MODEL_CLOUD=claude-sonnet-4-6 # fallback cloud
BIZ_MANAGER_MODEL=llama3.1:8b           # local via Ollama
BIZ_MANAGER_MODEL_CLOUD=claude-sonnet-4-6

# === ChromaDB (Docker) ===
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TOKEN=dev-token

# === Mémoire vectorielle ===
EMBED_MODEL=nomic-embed-text   # modèle Ollama pour les embeddings
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TOKEN=dev-token

# === Observabilité ===
LOGFIRE_TOKEN=your_logfire_token_here   # laisser vide pour mode local (console)
APP_VERSION=0.1.0

# === MCP — GitHub ===
GITHUB_TOKEN=your_github_token_here

# === MCP — Google Workspace ===
GOOGLE_CREDENTIALS_FILE=credentials.json  # télécharger depuis Google Cloud Console
GOOGLE_TOKEN_FILE=token.json              # généré automatiquement au 1er auth

# === MCP — CRM (HubSpot par défaut) ===
CRM_TYPE=hubspot
CRM_API_KEY=your_hubspot_private_app_token
CRM_BASE_URL=                             # laisser vide pour HubSpot

# === MCP — SEO ===
SEARCH_CONSOLE_SITE_URL=https://tonsite.com/
DATAFORSEO_LOGIN=your_dataforseo_login    # optionnel
DATAFORSEO_PASSWORD=your_dataforseo_password
