# === LLMs Cloud ===
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# === Ollama (Docker) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Modèles par défaut ===
DEV_SENIOR_MODEL=qwen2.5-coder:7b       # local via Ollama
DEV_SENIOR_MODEL_CLOUD=claude-sonnet-4-6 # fallback cloud
BIZ_MANAGER_MODEL=llama3.1:8b           # local via Ollama
BIZ_MANAGER_MODEL_CLOUD=claude-sonnet-4-6

# === ChromaDB (Docker) ===
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_TOKEN=dev-token

# === Observabilité ===
LOGFIRE_TOKEN=your_logfire_token_here

# === MCP Servers ===
GITHUB_TOKEN=your_github_token_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
