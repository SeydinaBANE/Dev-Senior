# ============================================================
# CONFIGURATION — copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env (il est dans .gitignore)
# ============================================================

# === OpenRouter (LLMs — une seule clé pour tous les modèles) ===
# Obtenir sur https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Modèles ===
DEV_SENIOR_MODEL=qwen/qwen-2.5-coder-7b-instruct
BIZ_MANAGER_MODEL=meta-llama/llama-3.1-8b-instruct
EMBED_MODEL=openai/text-embedding-3-small

# === Mémoire vectorielle (Qdrant) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333

# === Base de données (PostgreSQL — sessions persistantes) ===
DATABASE_URL=postgresql://agents:change-this-password@localhost:5432/agents_db
POSTGRES_DB=agents_db
POSTGRES_USER=agents
POSTGRES_PASSWORD=change-this-password          # ⚠ changer impérativement

# === Sessions Redis (optionnel — remplace PostgreSQL pour les sessions si défini) ===
# REDIS_URL=redis://localhost:6379/0             # décommenter pour activer Redis

# === API agents ===
# ⚠ OBLIGATOIRE en prod — laisser vide seulement en dev local
AGENTS_API_KEY=generate-a-strong-random-key-here
DOCS_ENABLED=true                              # false en prod (désactive Swagger)
CORS_ORIGINS=http://localhost:5173,http://localhost:5678,http://localhost:3000

# === Observabilité (Langfuse) ===
# Obtenir sur https://cloud.langfuse.com (ou self-hosted)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com       # changer si self-hosted
APP_VERSION=0.2.0

# === MCP — GitHub ===
GITHUB_TOKEN=your_github_token_here            # scopes requis : repo

# === MCP — Google Workspace ===
GOOGLE_CREDENTIALS_FILE=credentials.json       # télécharger depuis Google Cloud Console
GOOGLE_TOKEN_FILE=token.json                   # généré automatiquement au 1er lancement

# === MCP — CRM (HubSpot par défaut) ===
CRM_TYPE=hubspot
CRM_API_KEY=your_hubspot_private_app_token
CRM_BASE_URL=                                  # laisser vide pour HubSpot

# === MCP — SEO ===
SEARCH_CONSOLE_SITE_URL=https://tonsite.com/
DATAFORSEO_LOGIN=your_dataforseo_login         # optionnel
DATAFORSEO_PASSWORD=your_dataforseo_password   # optionnel

# === n8n ===
N8N_USER=admin
N8N_PASSWORD=change-this-strong-password       # ⚠ changer impérativement
AGENTS_API_URL=http://host.docker.internal:8080

# === Emails (pour les workflows n8n) ===
SENDER_EMAIL=ton@email.com
REPORT_RECIPIENTS=equipe@email.com
CONTENT_TEAM_EMAIL=content@email.com
SLACK_ALERT_CHANNEL=#alertes
